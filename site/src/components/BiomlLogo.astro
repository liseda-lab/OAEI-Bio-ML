---
// BioML composite logo — the OAEI diamond with the "BioML" wordmark in front
// and below (the A+B system Jon chose). Theme-adaptive via the .bml-* classes
// in global.css (--dia-* tokens flip with light/dark, incl. the manual toggle).
//   variant="full"     the full OAEI diamond (letters + edge words) + wordmark  (large use)
//   variant="compact"  a clean diamond (letters only) + wordmark                (medium use)
//   variant="mark"     just the clean diamond, no wordmark                      (header / favicon)
interface Props {
  variant?: 'full' | 'compact' | 'mark';
  class?: string;
  title?: string;
}
const { variant = 'full', class: klass = '', title = 'BioML — an OAEI Bio-ML track' } = Astro.props;

// diamond with the four OAEI edge words (faithful)
const diamondFull = `
  <rect class="bml-rect" x="27" y="27" width="74" height="74" rx="8" transform="rotate(45 64 64)" stroke-width="3"/>
  <text class="bml-ink" x="64" y="42" text-anchor="middle" dominant-baseline="central" font-size="27">O</text>
  <text class="bml-ink" x="41" y="66" text-anchor="middle" dominant-baseline="central" font-size="27">A</text>
  <text class="bml-ink" x="87" y="66" text-anchor="middle" dominant-baseline="central" font-size="27">E</text>
  <text class="bml-ink" x="64" y="90" text-anchor="middle" dominant-baseline="central" font-size="27">I</text>
  <text class="bml-word" x="34" y="30" text-anchor="middle" transform="rotate(-45 34 30)" font-size="7.6">Ontology</text>
  <text class="bml-word" x="94" y="30" text-anchor="middle" transform="rotate(45 94 30)" font-size="7.6">Alignment</text>
  <text class="bml-word" x="34" y="98" text-anchor="middle" transform="rotate(45 34 98)" font-size="7.6">Evaluation</text>
  <text class="bml-word" x="94" y="98" text-anchor="middle" transform="rotate(-45 94 98)" font-size="7.6">Initiative</text>`;

// clean diamond, letters only (legible at small sizes)
const diamondPlain = `
  <rect class="bml-rect" x="27" y="27" width="74" height="74" rx="9" transform="rotate(45 64 64)" stroke-width="3.2"/>
  <text class="bml-ink" x="64" y="43" text-anchor="middle" dominant-baseline="central" font-size="29">O</text>
  <text class="bml-ink" x="42" y="66" text-anchor="middle" dominant-baseline="central" font-size="29">A</text>
  <text class="bml-ink" x="86" y="66" text-anchor="middle" dominant-baseline="central" font-size="29">E</text>
  <text class="bml-ink" x="64" y="89" text-anchor="middle" dominant-baseline="central" font-size="29">I</text>`;

const wordmark = (x: number, y: number, s: number) =>
  `<text x="${x}" y="${y}" text-anchor="middle" class="bml-wm" font-size="${s}"><tspan>Bio</tspan><tspan class="bml-ml">ML</tspan></text>`;

let viewBox = '0 0 128 128';
let inner = diamondPlain;
if (variant === 'full') {
  viewBox = '0 0 264 172';
  inner = `<g transform="translate(78,2) scale(0.85)">${diamondFull}</g>${wordmark(132, 146, 52)}`;
} else if (variant === 'compact') {
  viewBox = '0 0 240 166';
  inner = `<g transform="translate(67.5,4) scale(0.82)">${diamondPlain}</g>${wordmark(120, 142, 52)}`;
}
---
<svg class={`bml-logo ${klass}`.trim()} viewBox={viewBox} role="img" aria-label={title} set:html={inner}></svg>
