---
// Hero animation — two small biomedical is-a HIERARCHIES (NCIT ↔ DOID) with
// labelled classes; correspondence links form between matched concepts:
// solid teal = equivalence, dashed amber = subsumption (a class ↔ a broader one).
// Lightweight hand-written Canvas2D (no dependency); pauses offscreen; a static
// labelled SVG shows for no-JS and prefers-reduced-motion.
---
<div class="hero-canvas-wrap" id="hero-align-wrap">
  <canvas id="hero-align" aria-label="Two biomedical ontologies (NCIT and DOID) shown as is-a hierarchies; their corresponding classes are aligned by equivalence and subsumption correspondences."></canvas>
  <svg class="fallback" viewBox="0 0 400 275" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
    <rect width="400" height="275" fill="#08131f"/>
    <g font-family="'Space Grotesk Variable', sans-serif" font-size="12" font-weight="600">
      <!-- faint is-a edges -->
      <g stroke="rgba(150,190,220,0.30)" stroke-width="1.2" fill="none">
        <path d="M70 55 L60 120"/><path d="M60 120 L58 200"/><path d="M70 55 L110 90"/>
        <path d="M330 55 L340 120"/><path d="M340 120 L342 200"/><path d="M330 55 L290 90"/>
      </g>
      <!-- correspondences -->
      <path d="M110 90 C200 90 200 90 290 90" stroke="#7fdcf4" stroke-width="2" fill="none"/>
      <path d="M60 120 C200 120 200 120 340 120" stroke="#7fdcf4" stroke-width="2" fill="none"/>
      <path d="M58 200 C200 200 200 120 340 120" stroke="#f0a53a" stroke-width="1.6" stroke-dasharray="5 4" fill="none"/>
      <g fill="#dfeaf5">
        <g text-anchor="middle">
          <rect x="42" y="45" width="56" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="70" y="59">Neoplasm</text>
          <rect x="86" y="80" width="52" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="112" y="94">Nevus</text>
          <rect x="30" y="110" width="62" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="61" y="124">Carcinoma</text>
          <rect x="34" y="190" width="48" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="58" y="204">BCC</text>
          <rect x="300" y="45" width="52" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="326" y="59">disease</text>
          <rect x="266" y="80" width="50" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="291" y="94">nevus</text>
          <rect x="312" y="110" width="52" height="20" rx="10" fill="rgba(12,26,38,0.85)" stroke="rgba(150,190,220,0.35)"/><text x="338" y="124">cancer</text>
        </g>
      </g>
    </g>
  </svg>
  <div class="cv-legend"><span><i style="background:#7fdcf4"></i>equivalence</span><span><i style="background:#f0a53a"></i>subsumption</span></div>
</div>

<style>
  .hero-canvas-wrap.cv-on .fallback { display: none; }
</style>

<script>
  (() => {
    const wrap = document.getElementById('hero-align-wrap');
    const canvas = document.getElementById('hero-align') as HTMLCanvasElement | null;
    if (!wrap || !canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const EQ = '#2bbfe3', EQL = '#7fdcf4', SUB = '#f0a53a', TXT = '#dfeaf5';
    let W = 0, H = 0, DPR = 1, t = 0, running = false, raf = 0;

    // node = [label, relX, relY]; is-a edges by index; correspondences [srcIdx, tgtIdx, type]
    const Ln: [string, number, number][] = [['Neoplasm', .16, .18], ['Nevus', .30, .35], ['Carcinoma', .13, .52], ['Melanoma', .26, .68], ['BCC', .14, .85]];
    const Rn: [string, number, number][] = [['disease', .84, .18], ['nevus', .70, .35], ['cancer', .87, .52], ['melanoma', .74, .68], ['carcinoma', .87, .85]];
    const Le = [[0, 1], [0, 2], [2, 3], [2, 4]];
    const Re = [[0, 1], [0, 2], [2, 3], [2, 4]];
    const CO: [number, number, 'eq' | 'sub'][] = [[3, 3, 'eq'], [2, 4, 'eq'], [1, 1, 'eq'], [4, 2, 'sub']];

    const resize = () => {
      const r = canvas.getBoundingClientRect();
      DPR = Math.min(2, window.devicePixelRatio || 1);
      W = Math.max(1, r.width); H = Math.max(1, r.height);
      canvas.width = Math.round(W * DPR); canvas.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    };
    const px = (n: [string, number, number]): [number, number] => [n[1] * W, n[2] * H];
    const rr = (x: number, y: number, w: number, h: number, r: number) => {
      ctx.beginPath();
      ctx.moveTo(x + r, y); ctx.arcTo(x + w, y, x + w, y + h, r); ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r); ctx.arcTo(x, y, x + w, y, r); ctx.closePath();
    };
    const pill = (x: number, y: number, label: string) => {
      const fs = Math.max(9, Math.round(H * 0.052));
      ctx.font = `600 ${fs}px 'Space Grotesk Variable', 'Space Grotesk', system-ui, sans-serif`;
      const w = ctx.measureText(label).width + 14, h = Math.round(H * 0.105);
      ctx.fillStyle = 'rgba(12,26,38,0.82)'; ctx.strokeStyle = 'rgba(150,190,220,0.35)'; ctx.lineWidth = 1;
      rr(x - w / 2, y - h / 2, w, h, h / 2); ctx.fill(); ctx.stroke();
      ctx.fillStyle = TXT; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(label, x, y + 0.5);
    };
    const tree = (nodes: [string, number, number][], edges: number[][]) => {
      ctx.strokeStyle = 'rgba(150,190,220,0.26)'; ctx.lineWidth = 1.2;
      for (const [a, b] of edges) { const p = px(nodes[a]), q = px(nodes[b]); ctx.beginPath(); ctx.moveTo(p[0], p[1]); ctx.lineTo(q[0], q[1]); ctx.stroke(); }
    };
    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      const g = ctx.createRadialGradient(W * 0.5, H * 0.12, 10, W * 0.5, H * 0.5, W * 0.8);
      g.addColorStop(0, 'rgba(30,70,105,0.35)'); g.addColorStop(1, 'rgba(8,19,31,0)');
      ctx.fillStyle = '#08131f'; ctx.fillRect(0, 0, W, H); ctx.fillStyle = g; ctx.fillRect(0, 0, W, H);
      tree(Ln, Le); tree(Rn, Re);
      CO.forEach((co, k) => {
        const A = px(Ln[co[0]]), B = px(Rn[co[1]]), sub = co[2] === 'sub';
        const cyc = ((t * 0.05) + k / CO.length) % 1;
        const prog = cyc < 0.35 ? cyc / 0.35 : 1;
        const alpha = cyc < 0.35 ? cyc / 0.35 : cyc >= 0.78 ? 1 - (cyc - 0.78) / 0.22 : 1;
        const col = sub ? SUB : EQ, mx = (A[0] + B[0]) / 2;
        ctx.save();
        ctx.globalAlpha = alpha * 0.95; ctx.strokeStyle = col; ctx.lineWidth = sub ? 1.6 : 2;
        if (sub) ctx.setLineDash([5, 4]);
        ctx.shadowColor = col; ctx.shadowBlur = 9;
        ctx.beginPath(); ctx.moveTo(A[0], A[1]);
        ctx.bezierCurveTo(mx, A[1], mx, B[1], A[0] + (B[0] - A[0]) * prog, A[1] + (B[1] - A[1]) * prog);
        ctx.stroke(); ctx.restore();
      });
      for (const n of Ln) { const p = px(n); pill(p[0], p[1], n[0]); }
      for (const n of Rn) { const p = px(n); pill(p[0], p[1], n[0]); }
      ctx.font = `600 ${Math.max(8, Math.round(H * 0.05))}px 'Inter Variable', 'Inter', system-ui, sans-serif`;
      ctx.fillStyle = 'rgba(190,215,235,0.6)';
      ctx.textAlign = 'left'; ctx.fillText('NCIT', W * 0.05, H * 0.08);
      ctx.textAlign = 'right'; ctx.fillText('DOID', W * 0.95, H * 0.08);
    };
    const loop = () => { t += 0.016; draw(); raf = requestAnimationFrame(loop); };
    const start = () => { if (running || reduce) return; running = true; raf = requestAnimationFrame(loop); };
    const stop = () => { running = false; cancelAnimationFrame(raf); };

    resize(); draw();
    wrap.classList.add('cv-on');
    if (document.fonts && (document.fonts as any).ready) (document.fonts as any).ready.then(draw);
    window.addEventListener('resize', () => { resize(); if (!running || reduce) draw(); });
    if ('IntersectionObserver' in window && !reduce) {
      new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? start() : stop())), { threshold: 0.05 }).observe(canvas);
    } else if (!reduce) start();
  })();
</script>
