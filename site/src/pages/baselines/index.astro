---
import fs from 'node:fs';
import path from 'node:path';
import { withBase } from '../../config';
import Base from '../../layouts/Base.astro';

// The page is generated from leaderboard.json (the machine-readable results
// file at the repo root) at build time — tables can never drift from the data.
// ROOT is derived from the working directory (always site/ under npm scripts):
// import.meta.url would point at the compiled chunk during `astro build`, so a
// source-relative path breaks for pages nested below src/pages/.
const ROOT = path.resolve(process.cwd(), '..');
const lb = JSON.parse(fs.readFileSync(path.join(ROOT, 'leaderboard.json'), 'utf8'));
const refCoh = JSON.parse(fs.readFileSync(path.join(ROOT, 'reference_coherence.json'), 'utf8'));
const sysCoh = JSON.parse(fs.readFileSync(path.join(ROOT, 'baseline_coherence.json'), 'utf8'));
const rt = JSON.parse(fs.readFileSync(path.join(ROOT, 'baseline_runtime.json'), 'utf8'));

// Coherence-table cell formatters. `null` counts/degrees render as an em dash;
// ELK lower bounds carry a dagger keyed to the footnote below the table.
const unsatCell = (n: number | null, lb2: boolean) =>
  n == null ? '—' : n.toLocaleString('en-GB') + (lb2 ? '†' : '');
const degCell = (d: number | null) => (d == null ? '—' : d === 0 ? '0%' : `${d}%`);

// Baseline-coherence cells: "38,034 (16.4%)". The degree is derived from the two
// stored integers rather than stored itself, so it can never disagree with them.
// toPrecision(3) — not a fixed number of decimals — because the degrees span four
// orders of magnitude: at 2dp, LogMap's 8 unsatisfiable classes would render as
// "0.00%" and read as coherent, which it is not.
const cohCell = (n: number | null, den: number) =>
  n == null ? '—' : `${n.toLocaleString('en-GB')} (${((100 * n) / den).toPrecision(3)}%)`;

// Runtime cells. Seconds are the recorded unit; the display steps up to minutes
// and hours because the runs span four orders of magnitude (24 s for LogMapLt
// on SNOMED-FMA, 24 h for LogMap on the same pair) and raw seconds would be
// unreadable at the top end. The thresholds sit above the round unit (90 s,
// 90 min) so nothing renders as a bare "1.0 min".
const durCell = (s: number | null | undefined) => {
  if (s == null) return '—';
  if (s < 90) return `${s < 10 ? s.toFixed(1) : Math.round(s)} s`;
  if (s < 5400) return `${(s / 60).toFixed(1)} min`;
  return `${(s / 3600).toFixed(1)} h`;
};

type Sys = { system: string } & Record<string, number>;
type Board = { headline: string; systems: Sys[] };
type Col = { k: string; l: string };
type Section = { key: 'global' | 'local'; kicker: string; title: string; cols: Col[] };

const f3 = (x: number) => (typeof x === 'number' ? x.toFixed(3) : '—');

// Each section's first metric column is its headline (matches lb[key].headline).
const sections: Section[] = [
  {
    key: 'global',
    kicker: 'Track 1 · Subtrack 1 — global equivalence alignment',
    title: 'Repaired coherence-aware P/R/F1',
    cols: [
      { k: 'f1_repaired', l: 'F1 (repaired)' },
      { k: 'precision_repaired', l: 'P (repaired)' },
      { k: 'recall_repaired', l: 'R (repaired)' },
    ],
  },
  {
    key: 'local',
    kicker: 'Track 1 · Subtrack 2 — local equivalence ranking',
    title: 'MRR and Hits@k',
    cols: [
      { k: 'mrr', l: 'MRR' },
      { k: 'hits_at_1', l: 'Hits@1' },
      { k: 'hits_at_5', l: 'Hits@5' },
      { k: 'hits_at_10', l: 'Hits@10' },
    ],
  },
];

const boardOf = (s: Section) => {
  const b: Board = lb[s.key];
  const headline = b.headline ?? s.cols[0].k;
  const systems = b.systems.slice().sort((a, b2) => (b2[headline] ?? -Infinity) - (a[headline] ?? -Infinity));
  return { headline, systems };
};

// Baseline coherence is reported per pair, not macro-averaged: two cells are missing,
// so an average would silently be taken over two pairs for some systems and three for
// others. HermiT gets a column only for NCIT-DOID — it is the one pair where the exact
// reasoner terminates, and empty columns for the other two would imply data we lack.
const COH_GROUPS: { pair: string; reasoners: ('elk' | 'hermit')[] }[] = [
  { pair: 'NCIT–DOID', reasoners: ['elk', 'hermit'] },
  { pair: 'SNOMED–FMA', reasoners: ['elk'] },
  { pair: 'SNOMED–NCIT', reasoners: ['elk'] },
];
const RLABEL = { elk: 'ELK', hermit: 'HermiT' } as const;
const cohPair = (p: string) => sysCoh.pairs.find((x: any) => x.pair === p);
// Row order follows the global P/R/F1 table above so the two read across as one block;
// both derive from leaderboard.json, so they cannot fall out of step.
const cohRows: string[] = boardOf(sections[0]).systems.map((s) => s.system);

// Runtime tables. Both take their row order from the leaderboard section they
// belong to, so every table on this page lists systems in the same order and
// none of them can fall out of step with leaderboard.json. Pair keys are stored
// with a hyphen (they are directory names upstream) and displayed with an en
// dash like everywhere else on the page.
const rtSections = [
  { key: 'global' as const, section: sections[0] },
  { key: 'local' as const, section: sections[1] },
].map((r) => ({
  ...r,
  data: rt[r.key],
  rows: boardOf(r.section).systems.map((s) => s.system),
}));
const rtPairs: string[] = rt.pairs;
const pairLabel = (p: string) => p.replace('-', '–');
---

<Base
  title="Baselines"
  description="Organiser baseline results for OAEI Bio-ML 2026: repaired coherence-aware P/R/F1 for global alignment, and MRR / Hits@k for local ranking."
>
  <div class="page-head">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={withBase('/')}>Home</a><span class="sep" aria-hidden="true">/</span><span aria-current="page">Baselines</span>
      </nav>
      <h1>Baselines</h1>
      <p class="lead">
        Organiser-run baseline systems for both competitions, published before the evaluation
        window. These are <strong>organiser baselines</strong> — participant submissions are not added
        to these tables. Participant results live on the CodaBench leaderboards and appear on the
        <a href={withBase('/results/')}>results page</a> now that the window is open (since 12 July 2026).
      </p>
    </div>
  </div>

  {sections.map((s, si) => {
    const { headline, systems } = boardOf(s);
    return (
      <section class="section" style={si === 0 ? 'border-top:none;' : undefined} aria-labelledby={`${s.key}-h`}>
        <div class="container">
          <p class="kicker">{s.kicker}</p>
          <h2 id={`${s.key}-h`}>{s.title}</h2>
          <p class="section-lede">
            Macro-averaged over the three pairs (NCIT–DOID, SNOMED–FMA, SNOMED–NCIT); sorted by the
            headline column. See <a href={withBase('/evaluation/')}>evaluation metrics</a>.
          </p>
          <div class="table-wrap">
            <table class="sortable">
              <thead>
                <tr>
                  <th data-col="0">System</th>
                  {s.cols.map((c, ci) => <th class="num" data-col={ci + 1}>{c.l}</th>)}
                </tr>
              </thead>
              <tbody>
                {systems.map((row, i) => (
                  <tr>
                    <td>{row.system}{row.system === 'Lexical-Baseline' && <a class="fn-ref" href="#lexical-baseline-note" aria-label="Footnote: what the Lexical-Baseline system is">*</a>}</td>
                    {s.cols.map((c, ci) => (
                      <td class="num">
                        {ci === 0 && i === 0 && c.k === headline
                          ? <span class="best">{f3(row[c.k])}</span>
                          : f3(row[c.k])}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    );
  })}

  <section class="section" aria-labelledby="note-h">
    <div class="container">
      <h2 id="note-h" style="font-size:1.05rem;">About these baselines</h2>
      <p style="font-size:0.88rem; color:var(--ink-3); max-width:78ch;">
        {lb.note ?? 'Organiser baselines, macro-averaged over the three pairs.'} The global-alignment
        headline is the repaired coherence-aware F1; local ranking
        is headlined by MRR. Full data:
        <a class="mono" href={withBase('/leaderboard.json')}>leaderboard.json</a>.
        Participant results appear on the <a href={withBase('/results/')}>results page</a>, fed by the
        CodaBench leaderboards. How long each baseline took, and the machine it ran on, are in
        <a href="#runtime">wall-clock times</a> below.
        <span id="lexical-baseline-note"><span class="fn-ref" aria-hidden="true">*</span> Lexical-Baseline
        is a character tri-gram similarity matcher, not an exact-string baseline.</span>
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="syscoh-h" id="baseline-coherence">
    <div class="container">
      <p class="kicker">Baseline coherence</p>
      <h2 id="syscoh-h">Baseline coherence — the alignments the systems produce</h2>
      <p class="section-lede">
        Alongside P/R/F1, each global alignment is checked with a reasoner: does the system's
        <strong>own</strong> alignment leave the merged ontology satisfiable? Each baseline's submitted
        mappings are merged with both ontologies and classified, giving the number of unsatisfiable named
        classes and the incoherence degree (that count over the merged named-class signature, in
        parentheses). <strong>Lower is better; 0 is coherent.</strong> Rows are in the same order as the
        P/R/F1 table above, so the two can be read across.
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th rowspan="2" scope="col">System</th>
              {COH_GROUPS.map((g) => (
                <th class="num" colspan={g.reasoners.length} scope="colgroup">{g.pair}</th>
              ))}
            </tr>
            <tr>
              {COH_GROUPS.flatMap((g) => g.reasoners.map((r) => (
                <th class="num" scope="col">{RLABEL[r]}</th>
              )))}
            </tr>
          </thead>
          <tbody>
            {cohRows.map((name) => (
              <tr>
                <td>{name}</td>
                {COH_GROUPS.flatMap((g) => {
                  const pd = cohPair(g.pair);
                  return g.reasoners.map((r) => (
                    <td class="num">{cohCell(pd?.systems?.[name]?.[r] ?? null, pd.union_class_count)}</td>
                  ));
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-size:0.82rem; color:var(--ink-3); max-width:80ch; margin-top:0.6rem;">
        Counted in the merged ontology (<span class="mono">O<sub>src</sub> ∪ O<sub>tgt</sub> ∪ M</span>),
        where <span class="mono">M</span> is the system's own alignment. Every <strong>ELK</strong> figure is
        a sound lower bound; <strong>HermiT</strong> is exact but only terminates on NCIT–DOID at this scale,
        so the SNOMED pairs carry ELK bounds only. As with the reference figures below, correspondences involving
        <span class="mono">owl:deprecated</span> classes are excluded as out-of-task, so the two tables are on
        the same basis. Two cells are genuinely unavailable (—): AML and LogMapLt on SNOMED–FMA did not
        produce a result. Coherence is <strong>not</strong> a quality ranking and does not track F1 — a system
        that maps very little scores well here, and LogMap and AML repair internally by design.
        Machine-readable data:
        <a class="mono" href={withBase('/baseline_coherence.json')}>baseline_coherence.json</a>.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="refcoh-h" id="reference-coherence">
    <div class="container">
      <p class="kicker">Reference coherence</p>
      <h2 id="refcoh-h">Reference coherence — before vs after repair</h2>
      <p class="section-lede">
        The Task-1 reference alignment is grounded in UMLS/Mondo and can be logically
        <strong>incoherent</strong>; the <a href={withBase('/repair/')}>repair procedure</a> removes or
        weakens the incoherence-inducing correspondences. This table reports the coherence of each pair's
        reference <strong>before</strong> and <strong>after</strong> repair — the number of unsatisfiable
        named classes in the merged ontology and the corresponding incoherence degree. All three repaired
        references are <strong>coherent (0 unsatisfiable classes)</strong>.
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Pair</th>
              <th class="num">Unsat. (before)</th>
              <th class="num">Incoherence degree (before)</th>
              <th class="num">Unsat. (after)</th>
              <th class="num">Incoherence degree (after)</th>
            </tr>
          </thead>
          <tbody>
            {refCoh.pairs.map((p: any) => (
              <tr>
                <td>{p.pair}</td>
                <td class="num">{unsatCell(p.unsat_before, p.unsat_before_lower_bound)}</td>
                <td class="num">{degCell(p.degree_before_pct)}</td>
                <td class="num">{unsatCell(p.unsat_after, false)}</td>
                <td class="num">{degCell(p.degree_after_pct)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p style="font-size:0.82rem; color:var(--ink-3); max-width:80ch; margin-top:0.6rem;">
        Unsatisfiable classes are counted in the merged ontology
        (<span class="mono">O<sub>src</sub> ∪ O<sub>tgt</sub> ∪ R</span>) under the ELK reasoner; the
        incoherence degree is that count over the merged named-class signature. † denotes an ELK lower
        bound (a sound under-approximation; the exact figure is pending). The all-equivalence standard
        SNOMED–FMA merge does not classify under ELK even at a 128 GB heap, so its before-repair figure is
        unavailable (—). Machine-readable data:
        <a class="mono" href={withBase('/reference_coherence.json')}>reference_coherence.json</a>.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="runtime-h" id="runtime">
    <div class="container">
      <p class="kicker">Runtime</p>
      <h2 id="runtime-h">Wall-clock times — and the machine that produced them</h2>
      <p class="section-lede">
        How long each baseline actually took, per pair and over all three. The Subtrack-1 figures cover the
        <strong>matching</strong> phase that produced the system's global alignment; the Subtrack-2 figures cover
        the <strong>ranking</strong> run behind the MRR / Hits@k above. Every run was on the one workstation
        specified below.
      </p>

      {rtSections.map((rs) => (
        <>
          <h3 class="rt-h">{rs.data.label}</h3>
          <p class="rt-sub">{rs.data.phase}</p>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>System</th>
                  {rtPairs.map((p) => <th class="num">{pairLabel(p)}</th>)}
                  <th class="num">All three</th>
                  <th>Ran on</th>
                </tr>
              </thead>
              <tbody>
                {rs.rows.map((name) => {
                  const r = rs.data.systems[name];
                  return (
                    <tr>
                      <td>{name}</td>
                      {rtPairs.map((p) => <td class="num">{durCell(r?.seconds?.[p])}</td>)}
                      <td class="num">{durCell(r?.total_seconds)}</td>
                      <td class="rt-res">{r?.resources ?? '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          <p class="rt-note">
            {rs.rows.filter((n) => rs.data.systems[n]?.note).map((n) => (
              <><strong>{n}:</strong> {rs.data.systems[n].note}{' '}</>
            ))}
          </p>
          <p class="rt-note"><em>Measured as:</em> {rs.data.source}</p>
        </>
      ))}

      <h3 class="rt-h">Hardware</h3>
      <p class="rt-sub">{rt.hardware.host}</p>
      <div class="table-wrap">
        <table>
          <tbody>
            <tr><th scope="row">CPU</th><td>{rt.hardware.cpu}</td></tr>
            <tr><th scope="row">Memory</th><td>{rt.hardware.memory}</td></tr>
            <tr><th scope="row">GPU</th><td>{rt.hardware.gpu}</td></tr>
            <tr><th scope="row">Storage</th><td>{rt.hardware.storage}</td></tr>
            <tr><th scope="row">OS</th><td>{rt.hardware.os}</td></tr>
            <tr><th scope="row">JVM</th><td>{rt.software.jvm}</td></tr>
            <tr><th scope="row">Python</th><td>{rt.software.python}</td></tr>
            <tr><th scope="row">Reasoner</th><td>{rt.software.reasoner}</td></tr>
          </tbody>
        </table>
      </div>
      <p class="rt-note">
        {rt.note} Measured {rt.measured}. Machine-readable data:
        <a class="mono" href={withBase('/baseline_runtime.json')}>baseline_runtime.json</a>.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="editions-h">
    <div class="container">
      <p class="kicker">Editions</p>
      <h2 id="editions-h">Baselines and results by edition</h2>
      <p class="section-lede">
        OAEI Bio-ML 2026 is the current edition. As the track matures, each edition's final baselines
        and participant results will be archived here, and changes between editions are recorded in the
        <a href={withBase('/changelog/')}>changelog</a>.
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Edition</th><th>Status</th><th>Baselines</th><th>Machine-readable snapshot</th></tr>
          </thead>
          <tbody>
            <tr>
              <td>2026</td>
              <td>current — evaluation &amp; leaderboard open since 12 July 2026</td>
              <td>this page</td>
              <td><a class="mono" href={withBase('/leaderboard.json')}>leaderboard.json</a></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Base>
